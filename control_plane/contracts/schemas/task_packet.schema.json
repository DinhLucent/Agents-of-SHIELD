{
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "session_id",
    "role",
    "secondary_roles",
    "mode",
    "execution_mode",
    "runtime_plan",
    "routing",
    "task_type",
    "domain",
    "risk_level",
    "goal",
    "summary",
    "rules",
    "context_budget",
    "modules",
    "context_fragments",
    "files",
    "tests",
    "handoff_refs",
    "memory_refs",
    "verification_plan",
    "expected_outputs",
    "acceptance_criteria"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "task_id": { "type": "string" },
    "session_id": { "type": "string" },
    "role": { "type": "string" },
    "secondary_roles": { "type": "array", "items": { "type": "string" } },
    "mode": { "type": "string" },
    "execution_mode": {
      "type": "object",
      "required": ["mode", "primary_role", "secondary_roles", "reason"],
      "properties": {
        "mode": { "type": "string" },
        "primary_role": { "type": "string" },
        "secondary_roles": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      }
    },
    "runtime_plan": {
      "type": "object",
      "required": ["mode", "steps", "assigned_roles", "review_required", "verification_profile"],
      "properties": {
        "mode": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role", "status"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "assigned_roles": { "type": "array", "items": { "type": "string" } },
        "review_required": { "type": "boolean" },
        "verification_profile": { "type": "string" }
      }
    },
    "routing": { "type": "object" },
    "task_type": { "type": "string" },
    "domain": { "type": "string" },
    "risk_level": { "type": "string" },
    "goal": { "type": "string" },
    "summary": { "type": "string" },
    "rules": { "type": "array", "items": { "type": "string" } },
    "context_budget": { "type": "object" },
    "modules": { "type": "array", "items": { "type": "string" } },
    "context_fragments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "files": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } },
    "handoff_refs": { "type": "array", "items": { "type": "string" } },
    "memory_refs": { "type": "array", "items": { "type": "string" } },
    "verification_plan": { "type": "array", "items": { "type": "string" } },
    "expected_outputs": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } }
  }
}
